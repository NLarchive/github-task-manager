{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-ide/component.schema.json",
  "title": "Agentic IDE Component Contract",
  "type": "object",
  "required": ["id", "type", "version", "path", "description", "inputs", "outputs", "files", "tests"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["tool", "agent", "subgraph", "workflow", "model"]
    },
    "version": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "number", "minimum": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "label": { "type": "string" },
    "path": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "lifecycle": { "type": "string" },
    "success_threshold": { "oneOf": [{ "type": "number" }, { "type": "string" }] },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tests": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
