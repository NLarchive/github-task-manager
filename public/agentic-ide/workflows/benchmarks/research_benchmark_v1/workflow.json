{
  "id": "research_benchmark",
  "type": "benchmark",
  "version": 1,
  "label": "research_benchmark",
  "path": "workflows/benchmarks/research_benchmark_v1",
  "description": "Runs research_workflow with live local inference and persists benchmark outputs for later review.",
  "lifecycle": "draft",
  "success_threshold": 1,
  "entry": "research_benchmark_runner",
  "state_schema": "state.js",
  "inputs": [
    {
      "name": "topic",
      "type": "string"
    },
    {
      "name": "benchmark_name",
      "type": "string"
    },
    {
      "name": "run_label",
      "type": "string"
    },
    {
      "name": "started_at",
      "type": "string"
    }
  ],
  "outputs": [
    {
      "name": "benchmark_record",
      "type": "object"
    },
    {
      "name": "output_path",
      "type": "string"
    }
  ],
  "nodes": [
    {
      "ref": "components/tools/research_benchmark_runner_v1"
    },
    {
      "ref": "components/tools/benchmark_result_writer_v1"
    }
  ],
  "edges": [
    {
      "id": "benchmark-report",
      "from": "research_benchmark_runner",
      "to": "benchmark_result_writer",
      "mapping": "report → report",
      "type": "data-flow"
    },
    {
      "id": "benchmark-meta",
      "from": "research_benchmark_runner",
      "to": "benchmark_result_writer",
      "mapping": "benchmark_meta → benchmark_meta",
      "type": "data-flow"
    }
  ],
  "files": [
    "workflow.json",
    "state.js",
    "tests/live.json"
  ],
  "tests": [
    "tests/live.json"
  ]
}