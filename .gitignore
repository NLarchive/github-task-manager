# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — web-github-task-manager
# ──────────────────────────────────────────────────────────────────────────────
# Defines which files and directories Git should never track.
# Organised by category: private data, secrets, dependencies, generated output,
# IDE/OS noise, test artefacts and local-only documentation.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Local / private task databases ──────────────────────────────────────────
# These folders contain personal or proprietary tasks and must never be committed.
public/tasksDB/local/
tools/design-archive/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
package-lock.json
.venv/

# ─── Legacy / external tool directories ──────────────────────────────────────
extract_project_spec/

# ─── Generated output directories ────────────────────────────────────────────
output/
outputs/

# ─── History files (derived, generated per-run) ───────────────────────────────
public/tasksDB/*/history/
public/tasksDB/*/*/history/

# ─── Derived task state and CSV files (avoid merge conflicts) ─────────────────
public/tasksDB/*/state/
public/tasksDB/*/state/**
public/tasksDB/*/tasks.csv
public/tasksDB/*/*/state/
public/tasksDB/*/*/state/**
public/tasksDB/*/*/tasks.csv

# ─── Secret / credential files — NEVER COMMIT THESE ──────────────────────────
public/config/github-token.local.js
public/config/github-token.js
public/config/access-secret.local.js
public/config/access-secret.js
public/config/worker-url.local.js
public/config/github-oauth.js
config/github-token.local.js
*.token
*.secret

# ─── Environment files ────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Build artifacts ──────────────────────────────────────────────────────────
dist/
build/

# ─── Test artifacts / reports ─────────────────────────────────────────────────
tests/artifacts/
playwright-report/
test-results/
.playwright-mcp/
.pytest_cache/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
live-test-run.log

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ─── Cloudflare Wrangler local state ──────────────────────────────────────────
tools/**/.wrangler/

# ─── Docs (local-only, not part of repo) ──────────────────────────────────────
.docs/

PROJECT_DOCS.md
memories/